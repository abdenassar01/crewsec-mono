+  private byte[] convertBitmapToESCPOSToPrint(Bitmap bitmap, int printerWidth) throws IOException {
+      ByteArrayOutputStream baos = new ByteArrayOutputStream();
+
+      final byte[] ESCPOS_INITIALIZE = {0x1B, 0x40};
+      final byte[] ESCPOS_SET_LINE_SPACE_24 = {0x1B, 0x33, 24};
+      final byte[] ESCPOS_SELECT_BIT_IMAGE_MODE = {0x1B, 0x2A, 0x21};
+      final byte[] ESCPOS_LINEFEED = {0x0A};
+
+      int originalWidth = bitmap.getWidth();
+      int originalHeight = bitmap.getHeight();
+      float scale = (float) printerWidth / (float) originalWidth;
+      int scaledHeight = Math.round(originalHeight * scale);
+      Bitmap scaledBitmap = Bitmap.createScaledBitmap(bitmap, printerWidth, scaledHeight, true);
+
+      baos.write(ESCPOS_INITIALIZE);
+      baos.write(CENTER_ALIGN);
+      baos.write(ESCPOS_SET_LINE_SPACE_24);
+
+      for (int y = 0; y < scaledHeight; y += 24) {
+          baos.write(ESCPOS_SELECT_BIT_IMAGE_MODE);
+          baos.write(new byte[]{(byte) (0x00ff & printerWidth), (byte) ((0xff00 & printerWidth) >> 8)});
+
+          for (int x = 0; x < printerWidth; x++) {
+              for (int byteIndex = 0; byteIndex < 3; byteIndex++) {
+                  byte slice = 0;
+                  // Each of the 3 bytes covers 8 pixels vertically
+                  for (int bit = 0; bit < 8; bit++) {
+                      int yyy = y + (byteIndex * 8) + bit;
+                      if (yyy < scaledHeight) {
+                          int color = scaledBitmap.getPixel(x, yyy);
+                          // Determine if the pixel is black or white (dithering)
+                          // A simple luminance threshold works well for thermal printers
+                          int r = Color.red(color);
+                          int g = Color.green(color);
+                          int b = Color.blue(color);
+                          int luminance = (int) (0.299 * r + 0.587 * g + 0.114 * b);
+
+                          if (luminance < 128) { // If darker than 50% grey, treat as black
+                              slice |= (byte) (1 << (7 - bit));
+                          }
+                      }
+                  }
+                  baos.write(slice);
+              }
+          }
+          // After each 24-pixel-high slice is sent, feed the line
+          baos.write(ESCPOS_LINEFEED);
+      }
+
+      // 4. Restore default line spacing and add a final line feed
+      baos.write(SET_LINE_SPACE_32);
+      baos.write(LINE_FEED);
+      baos.write(LINE_FEED);
+
+      return baos.toByteArray();
+  }
+
