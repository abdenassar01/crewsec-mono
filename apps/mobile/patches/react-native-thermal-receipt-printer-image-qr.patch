+  @Override
+  public void printImageData(String imageUrl, int imageWidth, int imageHeight, Callback errorCallback) {
+      if (this.mBluetoothSocket == null) {
+          errorCallback.invoke("Bluetooth connection is not built. Have you selected a printer?");
+          return;
+      }
+
+      // The imageWidth passed from JS is the desired width on the paper in pixels.
+      // 384 is a common default for 58mm printers.
+      final int printerWidth = imageWidth > 0 ? imageWidth : 384;
+
+      new Thread(new Runnable() {
+          @Override
+          public void run() {
+              try {
+                  // 1. Download the image from the URL
+                  Bitmap bitmapImage = getBitmapFromURL(imageUrl);
+                  if (bitmapImage == null) {
+                      Log.e(LOG_TAG, "Failed to download image or image is invalid: " + imageUrl);
+                      errorCallback.invoke("Failed to download image or image is invalid:" + imageUrl);
+                      return;
+                  }
+
+                  byte[] bytesToPrint = convertBitmapToESCPOSToPrint(bitmapImage, printerWidth);
+
+                  OutputStream printerOutputStream = mBluetoothSocket.getOutputStream();
+                  printerOutputStream.write(bytesToPrint);
+                  printerOutputStream.flush();
+                  printerOutputStream.close();
+                  Thread.sleep(1000);
+
+              } catch (Exception e) {
+                  Log.e(LOG_TAG, "Failed to print image.", e);
+                  errorCallback.invoke("Failed to print image: ");
+              }
+          }
+      }).start();
+  }
+
+  @Override
+  public void printImageBase64(final Bitmap bitmapImage, int imageWidth, int imageHeight,Callback errorCallback) {
+      if(bitmapImage == null) {
+          errorCallback.invoke("image not found");
+          return;
+      }
+
+      if (this.mBluetoothSocket == null) {
+          errorCallback.invoke("bluetooth connection is not built, may be you forgot to connectPrinter");
+          return;
+      }
+
+      final BluetoothSocket socket = this.mBluetoothSocket;
+
+      new Thread(new Runnable() {
+          @Override
+          public void run() {
+              try {
+                  // This method uses the older printing logic. It can be left as-is
+                  // or updated to use the new `convertBitmapToESCPOSToPrint` helper for consistency.
+                  // For now, we leave it as it was.
+                  int[][] pixels = getPixelsSlow(bitmapImage, imageWidth, imageHeight);
+                  OutputStream printerOutputStream = socket.getOutputStream();
+
+                  printerOutputStream.write(SET_LINE_SPACE_24);
+                  printerOutputStream.write(CENTER_ALIGN);
+
+                  for (int y = 0; y < pixels.length; y += 24) {
+                      printerOutputStream.write(SELECT_BIT_IMAGE_MODE);
+                      printerOutputStream.write(new byte[]{(byte)(0x00ff & pixels[y].length),
+                              (byte)((0xff00 & pixels[y].length) >> 8)});
+                      for (int x = 0; x < pixels[y].length; x++) {
+                          printerOutputStream.write(recollectSlice(y, x, pixels));
+                      }
+                      printerOutputStream.write(LINE_FEED);
+                  }
+                  printerOutputStream.write(SET_LINE_SPACE_32);
+                  printerOutputStream.write(LINE_FEED);
+                  printerOutputStream.flush();
+              } catch (IOException e) {
+                  Log.e(LOG_TAG, "failed to print data", e);
+              }
+          }
+      }).start();
+  }
 }
