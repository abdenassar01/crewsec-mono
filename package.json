{
  "name": "crewsec-all",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @crewsec/convex dev",
    "dev:web": "pnpm --filter web dev",
    "dev:mobile": "pnpm --filter crewsec start",
    "dev:all": "npm-run-all --parallel dev dev:web dev:mobile",
    "build:web": "pnpm --filter web build",
    "build:mobile": "pnpm --filter crewsec build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "packageManager": "pnpm@9.12.3",
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1",
      "convex-helpers": "0.1.100"
    },
    "patchedDependencies": {
      "react-native-thermal-receipt-printer-image-qr": "apps/mobile/patches/react-native-thermal-receipt-printer-image-qr.patch"
    }
  }
}
